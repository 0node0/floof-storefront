---
const currentYear = new Date().getFullYear();
const shopLinks = [
  { href: "/store", label: "All Products" },
  { href: "/store?cat=tees", label: "T-Shirts" },
  { href: "/store?cat=hoodies", label: "Hoodies" },
  { href: "/checkout", label: "Cart & Checkout" },
];
const infoLinks = [
  { href: "/about", label: "About Floof" },
  { href: "/shipping-returns", label: "Shipping & Returns" },
  { href: "/contact", label: "Contact Us" },
  { href: "/privacy", label: "Privacy Policy" },
  { href: "/terms", label: "Terms of Service" },
];
---
{/* Hallmark · footer: Ft5 statement · design-system: design.md */}
<footer class="mt-auto border-t border-floof-dark/8 bg-floof-sand/60">
  <div class="mx-auto max-w-7xl px-6 py-16 md:py-20">
    <!-- Statement -->
    <div class="max-w-2xl">
      <a href="/" class="font-display text-3xl md:text-4xl font-semibold text-floof-dark tracking-tight">
        Floof
      </a>
      <p class="mt-5 font-display text-2xl md:text-3xl leading-snug text-floof-dark/90">
        Soft blanks. Louder slogans.<br class="hidden sm:block" />
        <span class="text-floof-pink">Zero warehouse dust.</span>
      </p>
      <p class="mt-4 text-sm text-floof-dark/55 leading-relaxed max-w-md">
        Fun, witty threads from Southwest Florida — designed with Gulf Coast energy, printed fresh when you order.
      </p>
    </div>

    <div class="mt-12 grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
      <nav aria-label="Shop">
        <p class="eyebrow">Shop</p>
        <ul class="mt-4 space-y-2.5">
          {shopLinks.map((l) => (
            <li>
              <a href={l.href} class="text-sm text-floof-dark/65 hover:text-floof-pink transition-colors">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <nav aria-label="Help">
        <p class="eyebrow">Help</p>
        <ul class="mt-4 space-y-2.5">
          {infoLinks.map((l) => (
            <li>
              <a href={l.href} class="text-sm text-floof-dark/65 hover:text-floof-pink transition-colors">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <div>
        <p class="eyebrow">Stay in the loop</p>
        <p class="mt-4 text-sm text-floof-dark/55">First dibs on new drops &amp; SWFL exclusives.</p>
        <form class="mt-4 flex flex-wrap gap-2" action="/contact" method="get" aria-label="Newsletter signup">
          <label for="footer-email" class="sr-only">Email</label>
          <input
            id="footer-email"
            type="email"
            name="email"
            required
            placeholder="you@email.com"
            class="min-w-0 flex-1 rounded-full border border-floof-dark/12 bg-white/80 px-4 py-2.5 text-sm text-floof-dark placeholder:text-floof-dark/35 focus:border-floof-pink focus:outline-none"
          />
          <button type="submit" class="btn btn--sm shrink-0">
            Join
          </button>
        </form>
        <p class="mt-2 text-[11px] text-floof-dark/35">No spam. Unsubscribe anytime.</p>
        <div class="mt-6 flex gap-4">
          <a href="https://instagram.com/floof" target="_blank" rel="noopener noreferrer" class="text-floof-dark/40 hover:text-floof-pink transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://tiktok.com/@floof" target="_blank" rel="noopener noreferrer" class="text-floof-dark/40 hover:text-floof-pink transition-colors" aria-label="TikTok">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="mt-14 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 border-t border-floof-dark/8 pt-8">
      <p class="text-sm text-floof-dark/40">&copy; {currentYear} Floof. Made in SW Florida.</p>
      <p class="text-xs text-floof-dark/35">
        Fulfilled by <a href="https://www.printful.com" target="_blank" rel="noopener noreferrer" class="underline hover:text-floof-dark/55">Printful</a>
        &middot; Payments by <a href="https://stripe.com" target="_blank" rel="noopener noreferrer" class="underline hover:text-floof-dark/55">Stripe</a>
      </p>
    </div>
  </div>
</footer>
