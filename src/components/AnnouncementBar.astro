---
import Icon from "@/components/Icon.astro"
---
<div class="bg-floof-dark text-white text-center text-xs sm:text-sm py-2.5 px-4">
  <p class="font-medium tracking-wide inline-flex flex-wrap items-center justify-center gap-x-2 gap-y-1">
    <Icon name="star" class="w-3.5 h-3.5 text-floof-yellow shrink-0" />
    <span>Free shipping over $75</span>
    <span class="text-white/30 hidden sm:inline">·</span>
    <span class="hidden sm:inline">Printed fresh &amp; ships from the US</span>
    <span class="text-white/30 hidden sm:inline">·</span>
    <a href="/shipping-returns" class="underline underline-offset-2 text-floof-yellow hover:text-white hidden sm:inline">
      30-day returns
    </a>
  </p>
</div>
