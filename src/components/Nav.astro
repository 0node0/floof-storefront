---
import CartBadge from "@/components/CartBadge";

const pathname = Astro.url.pathname;
const links = [
  { href: "/store", label: "Shop" },
  { href: "/store?cat=tees", label: "Tees" },
  { href: "/store?cat=hoodies", label: "Hoodies" },
  { href: "/about", label: "About" },
  { href: "/shipping-returns", label: "Shipping" },
];

function isActive(href: string) {
  if (href === "/store") return pathname === "/store" || pathname.startsWith("/products");
  return pathname === href || pathname.startsWith(href + "/");
}
---
<header class="sticky top-0 z-50 bg-floof-cream/95 backdrop-blur-md border-b border-floof-dark/5">
  <nav class="mx-auto flex items-center justify-between px-6 py-3.5 max-w-7xl" aria-label="Main">
    <a href="/" class="text-2xl font-bold tracking-tight text-floof-pink hover:text-floof-coral transition-colors" aria-label="Floof home">
      FLOOF
    </a>
    <div class="hidden md:flex items-center gap-7">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={[
            "text-sm font-medium transition-colors",
            isActive(l.href) ? "text-floof-pink" : "text-floof-dark/70 hover:text-floof-pink",
          ]}
          aria-current={isActive(l.href) ? "page" : undefined}
        >
          {l.label}
        </a>
      ))}
    </div>
    <div class="flex items-center gap-3">
      <a
        href="/checkout"
        class="hidden sm:inline-flex items-center rounded-full bg-floof-pink px-4 py-2 text-xs font-semibold text-white hover:bg-floof-coral transition-colors"
      >
        Cart
      </a>
      <CartBadge client:load />
      <button
        id="mobile-btn"
        type="button"
        class="md:hidden flex items-center text-floof-dark/70 p-1"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
        </svg>
      </button>
    </div>
  </nav>
  <div id="mobile-menu" class="hidden md:hidden border-t border-floof-dark/5 px-6 py-3 bg-floof-cream">
    {links.map((l) => (
      <a href={l.href} class="block py-2.5 text-sm font-medium text-floof-dark/70 hover:text-floof-pink transition-colors">
        {l.label}
      </a>
    ))}
    <a href="/checkout" class="mt-2 block rounded-full bg-floof-pink py-2.5 text-center text-sm font-semibold text-white">
      View cart
    </a>
  </div>
</header>
<script is:inline>
  const btn = document.getElementById("mobile-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    btn.setAttribute("aria-expanded", open ? "true" : "false");
    btn.setAttribute("aria-label", open ? "Close menu" : "Open menu");
  });
</script>
