---
interface Props {
  compact?: boolean
}
const { compact = false } = Astro.props
const items = [
  { icon: "🚚", title: "Ships from the US", body: "Print-on-demand — made when you order" },
  { icon: "🔒", title: "Secure checkout", body: "Card payments powered by Stripe" },
  { icon: "↩️", title: "Easy returns", body: "30 days on unworn items" },
  { icon: "🌴", title: "SWFL brand", body: "Designed with Gulf Coast energy" },
]
---
<section class:list={["border-y border-floof-dark/5 bg-white", compact ? "py-6" : "py-10"]}>
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid grid-cols-2 gap-6 lg:grid-cols-4">
      {items.map((item) => (
        <div class="flex flex-col sm:flex-row sm:items-start gap-2 sm:gap-3 text-center sm:text-left">
          <span class="text-2xl sm:text-xl" aria-hidden="true">{item.icon}</span>
          <div>
            <p class="text-sm font-semibold text-floof-dark">{item.title}</p>
            <p class="mt-0.5 text-xs text-floof-dark/50 leading-relaxed">{item.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
