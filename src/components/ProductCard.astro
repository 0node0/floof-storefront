---
import type { FloofProduct } from "@/lib/product"
import { colorMap, categoryLabels } from "@/lib/product"

interface Props {
  product: FloofProduct
  priority?: boolean
}
const { product, priority = false } = Astro.props
const catLabel = categoryLabels[product.category] || product.category
---
<a
  href={`/products/${product.slug}`}
  class="card-surface group block overflow-hidden"
>
  <div class="relative aspect-square overflow-hidden bg-floof-sand p-6 sm:p-8 flex items-center justify-center">
    {product.isWip && (
      <span class="absolute top-3 left-3 z-10 rounded-full bg-floof-dark/90 px-2.5 py-1 text-[10px] font-mono font-medium uppercase tracking-wider text-floof-yellow">
        Preview
      </span>
    )}
    <span class="absolute top-3 right-3 z-10 rounded-full bg-white/90 px-2.5 py-1 text-[10px] font-medium uppercase tracking-wider text-floof-dark/55 opacity-0 group-hover:opacity-100 transition-opacity">
      View
    </span>
    {product.image ? (
      <img
        src={product.image}
        alt={`${product.name} — Floof apparel`}
        class="w-full h-full object-contain group-hover:scale-[1.04] transition-transform duration-300"
        loading={priority ? "eager" : "lazy"}
        width="400"
        height="400"
      />
    ) : (
      <span class="font-display text-2xl md:text-3xl font-semibold text-floof-dark/80 leading-tight text-center px-2">
        {product.phrase}
      </span>
    )}
  </div>
  <div class="p-5">
    <p class="eyebrow">{catLabel}</p>
    <h3 class="mt-1.5 font-display text-lg font-semibold text-floof-dark group-hover:text-floof-pink transition-colors line-clamp-2">
      {product.name}
    </h3>
    <p class="mt-1 text-sm text-floof-dark/50 line-clamp-2">{product.description}</p>
    <div class="mt-3 flex items-center justify-between gap-2">
      <div>
        <span class="text-lg font-semibold text-floof-pink tabular-nums">${product.price.toFixed(2)}</span>
        {product.sizes.length > 0 && (
          <p class="text-[11px] font-mono text-floof-dark/40 mt-0.5">
            {product.sizes[0]}–{product.sizes[product.sizes.length - 1]}
          </p>
        )}
      </div>
      {product.colors.length > 0 && (
        <div class="flex gap-1 items-center" aria-label={`${product.colors.length} colors`}>
          {product.colors.slice(0, 5).map((color) => (
            <span
              class="inline-block w-4 h-4 rounded-full border border-floof-dark/15 shadow-sm"
              style={`background: ${colorMap[color] || "#888"}`}
              title={color}
            />
          ))}
          {product.colors.length > 5 && (
            <span class="text-[10px] text-floof-dark/40">+{product.colors.length - 5}</span>
          )}
        </div>
      )}
    </div>
  </div>
</a>
