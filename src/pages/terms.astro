---
import Layout from "@/layouts/Layout.astro";
---
<Layout title="Terms of Service">
  <div class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="font-display text-3xl font-semibold text-floof-dark">Terms of Service</h1><p class="mt-2 text-sm text-floof-dark/50">Last updated: June 2026</p>
    <div class="mt-8 space-y-8 text-floof-dark/70 leading-relaxed">
      <section><h2 class="text-xl font-semibold text-floof-dark">Overview</h2><p>By using floof.space, you agree to these terms.</p></section>
      <section><h2 class="text-xl font-semibold text-floof-dark">Products</h2><p>All products are print-on-demand, fulfilled through Printful. Colors may vary slightly from what you see on screen.</p></section>
      <section><h2 class="text-xl font-semibold text-floof-dark">Orders & Shipping</h2><p>Orders are typically produced and shipped within 5-10 business days. Shipping times vary by location.</p></section>
      <section><h2 class="text-xl font-semibold text-floof-dark">Returns</h2><p>Not happy with your order? Reach out within 30 days and we'll make it right.</p></section>
      <section><h2 class="text-xl font-semibold text-floof-dark">Contact</h2><p>Questions? Email <a href="mailto:hello@floof.space" class="text-floof-pink hover:underline">hello@floof.space</a>.</p></section>
    </div>
  </div>
</Layout>