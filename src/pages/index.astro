---
import Layout from "@/layouts/Layout.astro";
import ProductCard from "@/components/ProductCard.astro";
import TrustBar from "@/components/TrustBar.astro";
import Icon from "@/components/Icon.astro";
import PlayStickers from "@/components/PlayStickers";
import MoodBar from "@/components/MoodBar.astro";
import VibeMarquee from "@/components/VibeMarquee.astro";
import { listProducts } from "@/lib/medusa";
import { mapProduct, type FloofProduct } from "@/lib/product";

export const prerender = false;

let products: FloofProduct[] = [];
try {
  const { products: raw } = await listProducts();
  products = raw.map(mapProduct).slice(0, 8);
} catch {}

const ogImage = products[0]?.image || "/favicon.svg";
const cats: { href: string; label: string; icon: string; blurb: string; tint: string }[] = [
  { href: "/store?cat=tees", label: "T-Shirts", icon: "shirt", blurb: "Everyday soft tees", tint: "bg-floof-yellow/35" },
  { href: "/store?cat=hoodies", label: "Hoodies", icon: "hoodie", blurb: "Cozy Gulf nights", tint: "bg-floof-ocean/20" },
  { href: "/store", label: "Full shop", icon: "spark", blurb: "See everything", tint: "bg-floof-pink/15" },
];
const heroImg = products[0]?.image;
---
<Layout
  title="Fun, witty threads from SW Florida"
  description="Floof is a fun, young, vibrant clothing brand from Southwest Florida. T-shirts, hoodies & more — printed fresh when you order."
  image={ogImage}
>
  {/* Bright SWFL sun-splash hero */}
  <section class="relative overflow-hidden sun-wash">
    <PlayStickers client:load />
    <div class="relative mx-auto max-w-7xl px-6 py-16 md:py-24 lg:py-28">
      <div class="grid items-center gap-12 lg:grid-cols-12">
        <div class="lg:col-span-6 xl:col-span-5">
          <p class="eyebrow">Southwest Florida · sun-chasers only</p>
          <h1 class="mt-4 font-display text-[clamp(2.6rem,5.5vw+0.5rem,4.25rem)] font-extrabold text-floof-dark leading-[1.02]">
            Life&rsquo;s too short for{" "}
            <span class="text-floof-gradient">boring clothes.</span>
          </h1>
          <p class="mt-6 text-lg text-floof-dark/65 max-w-md leading-relaxed">
            Fun, witty threads for beach bums and anyone who refuses to take themselves too seriously — printed fresh, never warehouse-stale.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/store" class="btn btn--lg">
              Shop the collection
            </a>
            <a href="/about" class="btn btn--outline btn--lg">
              Our story
            </a>
          </div>
          <dl class="mt-10 flex flex-wrap gap-x-6 gap-y-3 text-sm text-floof-dark/55">
            <div class="inline-flex items-center gap-2">
              <Icon name="truck" class="w-4 h-4 text-floof-pink" />
              <dd>Free ship $75+</dd>
            </div>
            <div class="inline-flex items-center gap-2">
              <Icon name="pin" class="w-4 h-4 text-floof-ocean" />
              <dd>Printed in the US</dd>
            </div>
            <div class="inline-flex items-center gap-2">
              <Icon name="return" class="w-4 h-4 text-floof-mint" />
              <dd>30-day returns</dd>
            </div>
          </dl>
        </div>
        <div class="lg:col-span-6 xl:col-span-7">
          <div class="relative mx-auto max-w-lg lg:max-w-none">
            <div
              class="absolute -inset-3 rounded-[1.5rem] opacity-70 blur-2xl"
              style="background: linear-gradient(135deg, oklch(88% 0.16 95 / 0.55), oklch(66% 0.21 25 / 0.35), oklch(68% 0.13 210 / 0.4));"
              aria-hidden="true"
            ></div>
            <div class="relative aspect-[4/5] sm:aspect-square rounded-[1.35rem] bg-white p-6 md:p-10 shadow-[0_24px_60px_-18px_oklch(55%_0.1_25_/_0.28)] outline outline-2 outline-white flex items-center justify-center overflow-hidden">
              {heroImg ? (
                <img
                  src={heroImg}
                  alt="Featured Floof apparel"
                  class="w-full h-full object-contain"
                  width="560"
                  height="560"
                  loading="eager"
                />
              ) : (
                <p class="font-display text-3xl md:text-4xl text-floof-dark/25 text-center px-6 font-bold">
                  Soft blanks.<br />Louder slogans.
                </p>
              )}
            </div>
            <button
              type="button"
              class="absolute -bottom-3 -left-2 sm:left-4 rounded-full bg-floof-pink text-white px-4 py-2 text-xs font-mono font-semibold uppercase tracking-wider shadow-lg shadow-floof-pink/30 cursor-pointer"
              data-play="poke"
              data-play-msg="fresh off the press!"
            >
              Made to order
            </button>
            <button
              type="button"
              class="absolute -top-2 -right-1 sm:right-4 rounded-full bg-floof-yellow text-floof-dark px-3 py-1.5 text-[11px] font-bold uppercase tracking-wide shadow-md cursor-pointer"
              data-play="poke"
              data-play-msg="maximum SWFL!"
            >
              SWFL vibes
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <VibeMarquee />
  <TrustBar />
  <MoodBar />

  <section class="mx-auto max-w-7xl px-6 py-14">
    <div class="mb-8 max-w-xl">
      <p class="eyebrow">Shop by vibe</p>
      <h2 class="mt-2 font-display text-2xl md:text-3xl font-bold text-floof-dark">Find your fit</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-3">
      {cats.map((c) => (
        <a
          href={c.href}
          class="card-surface group block p-8 text-left"
          data-play-tilt
        >
          <span class:list={["inline-flex h-12 w-12 items-center justify-center rounded-2xl text-floof-dark group-hover:scale-110 transition-transform", c.tint]}>
            <Icon name={c.icon} class="w-6 h-6" />
          </span>
          <p class="mt-4 font-display text-lg font-bold text-floof-dark group-hover:text-floof-pink transition-colors">{c.label}</p>
          <p class="mt-1 text-sm text-floof-dark/50">{c.blurb}</p>
          <p class="mt-3 text-[11px] font-mono uppercase tracking-wider text-floof-ocean opacity-0 group-hover:opacity-100 transition-opacity">
            tilt me · then go →
          </p>
        </a>
      ))}
    </div>
  </section>

  {products.length > 0 && (
    <section class="border-y border-floof-dark/5 bg-floof-sand/70">
      <div class="mx-auto max-w-7xl px-6 py-16 md:py-20">
        <div class="flex items-end justify-between gap-4 mb-10">
          <div>
            <p class="eyebrow">New drops</p>
            <h2 class="mt-2 font-display text-3xl font-bold md:text-4xl text-floof-dark">Fan favorites</h2>
          </div>
          <a href="/store" class="text-sm font-semibold text-floof-pink underline underline-offset-4 shrink-0">View all</a>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {products.slice(0, 4).map((p, i) => <ProductCard product={p} priority={i < 2} />)}
        </div>
        {products.length > 4 && (
          <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
            {products.slice(4, 8).map((p) => <ProductCard product={p} />)}
          </div>
        )}
      </div>
    </section>
  )}

  {products.length === 0 && (
    <section class="mx-auto max-w-3xl px-6 py-20 text-center">
      <p class="font-display text-2xl font-bold text-floof-dark">No products yet — check back soon!</p>
    </section>
  )}

  <section class="relative overflow-hidden">
    <div class="absolute inset-0 sun-wash opacity-80" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-3xl px-6 py-20 text-center">
      <p class="eyebrow">Why Floof</p>
      <h2 class="mt-3 font-display text-2xl md:text-3xl font-bold text-floof-dark leading-snug">
        Soft blanks. Louder slogans.<br class="hidden sm:block" /> Zero warehouse dust.
      </h2>
      <p class="mt-4 text-floof-dark/60 leading-relaxed">
        We design in SW Florida and print each order fresh. Better for small drops, better for the planet than piles of deadstock, and always ready for the next silly idea.
      </p>
      <a href="/store" class="btn btn--lg mt-8">
        Shop now
      </a>
    </div>
  </section>
</Layout>
