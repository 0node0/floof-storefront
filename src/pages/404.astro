---
import Layout from "@/layouts/Layout.astro";
import Icon from "@/components/Icon.astro";
---
<Layout title="404 — Not Found">
  <section class="mx-auto max-w-2xl px-6 py-20 text-center">
    <span class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-floof-sand text-floof-coral mb-6">
      <Icon name="spark" class="w-8 h-8" size={32} />
    </span>
    <h1 class="font-display text-4xl font-semibold text-floof-dark">404</h1>
    <p class="mt-4 text-lg text-floof-dark/60">That page got lost in the Gulf breeze.</p>
    <a href="/" class="btn mt-8">
      Back to home
    </a>
  </section>
</Layout>
