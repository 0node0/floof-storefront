---
import Layout from "@/layouts/Layout.astro";
import ProductCard from "@/components/ProductCard.astro";
import type { FloofProduct } from "@/components/ProductCard.astro";
import { listProducts } from "@/lib/medusa";

let all: FloofProduct[] = [];
try {
  const { products } = await listProducts();
  all = products.map(p => ({
    id: p.id, slug: p.handle, name: p.title,
    phrase: p.title.split(" ").slice(0, 3).join(" "),
    description: p.description || "", price: (p.variants?.[0]?.prices?.[0]?.amount || 0) / 100,
    category: (p.metadata?.category as string) || "tees",
    colors: [...new Set(p.variants?.map(v => v.options?.find(o => o.option?.title === "Color")?.value).filter(Boolean) as string[])],
    image: p.images?.[0]?.url || "",
  }));
} catch {}
---
<Layout title="Shop" description="Browse all Floof products.">
  <section class="bg-floof-dark text-white py-16"><div class="mx-auto max-w-7xl px-6 text-center"><h1 class="text-4xl font-bold md:text-5xl">The <span class="text-floof-gradient">Collection</span></h1></div></section>
  {all.length === 0 && <div class="mx-auto max-w-2xl px-6 py-20 text-center"><p class="text-2xl font-bold text-floof-dark">No products yet</p><p class="mt-3 text-floof-dark/50">Add products in Printful and run the seed command.</p></div>}
  {all.length > 0 && <section class="mx-auto max-w-7xl px-6 py-12"><div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">{all.map(p => <ProductCard product={p} />)}</div></section>}
</Layout>