---
import Layout from "@/layouts/Layout.astro";
import ProductCard from "@/components/ProductCard.astro";
import TrustBar from "@/components/TrustBar.astro";
import { listProducts } from "@/lib/medusa";
import { mapProduct, categoryLabels, type FloofProduct } from "@/lib/product";

export const prerender = false;

const catParam = Astro.url.searchParams.get("cat") || "all";
const sortParam = Astro.url.searchParams.get("sort") || "featured";

let all: FloofProduct[] = [];
try {
  const { products } = await listProducts();
  all = products.map(mapProduct);
} catch {}

const categories = [
  { id: "all", label: "All" },
  ...Object.entries(categoryLabels).map(([id, label]) => ({ id, label })),
].filter((c) => c.id === "all" || all.some((p) => p.category === c.id));

let filtered =
  catParam === "all" ? all : all.filter((p) => p.category === catParam);

if (sortParam === "price-asc") {
  filtered = [...filtered].sort((a, b) => a.price - b.price);
} else if (sortParam === "price-desc") {
  filtered = [...filtered].sort((a, b) => b.price - a.price);
} else if (sortParam === "name") {
  filtered = [...filtered].sort((a, b) => a.name.localeCompare(b.name));
}

const countLabel =
  filtered.length === 1 ? "1 product" : `${filtered.length} products`;
---
<Layout
  title={catParam !== "all" ? categoryLabels[catParam] || "Shop" : "Shop"}
  description="Browse Floof tees, hoodies, and more — witty SW Florida apparel, printed fresh when you order."
>
  <section class="border-b border-floof-dark/6 bg-floof-sand/50">
    <div class="mx-auto max-w-7xl px-6 py-12 md:py-16">
      <p class="eyebrow">Shop</p>
      <h1 class="mt-2 font-display text-4xl font-semibold md:text-5xl text-floof-dark">
        The Collection
      </h1>
      <p class="mt-3 text-floof-dark/55 text-sm md:text-base max-w-xl">
        Soft blanks, loud slogans. Pick a size — we print it fresh.
      </p>
    </div>
  </section>

  <TrustBar compact />

  {all.length === 0 && (
    <div class="mx-auto max-w-2xl px-6 py-20 text-center">
      <p class="font-display text-2xl font-semibold text-floof-dark">No products yet</p>
      <p class="mt-3 text-floof-dark/50">Check back soon — new drops are on the way.</p>
    </div>
  )}

  {all.length > 0 && (
    <section class="mx-auto max-w-7xl px-6 py-10 md:py-12">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between border-b border-floof-dark/6 pb-6">
        <div class="flex flex-wrap gap-2" role="tablist" aria-label="Category">
          {categories.map((c) => {
            const href =
              c.id === "all"
                ? `/store?sort=${sortParam}`
                : `/store?cat=${c.id}&sort=${sortParam}`;
            const active = catParam === c.id;
            return (
              <a
                href={href}
                role="tab"
                aria-selected={active}
                class:list={[
                  "rounded-full px-4 py-2 text-sm font-medium transition-colors whitespace-nowrap",
                  active
                    ? "bg-floof-dark text-floof-cream"
                    : "bg-white text-floof-dark/70 ring-1 ring-floof-dark/10 hover:ring-floof-pink/40",
                ]}
              >
                {c.label}
              </a>
            );
          })}
        </div>
        <div class="flex items-center gap-3">
          <p class="text-sm font-mono text-floof-dark/45">{countLabel}</p>
          <label class="sr-only" for="sort">Sort</label>
          <select
            id="sort"
            class="rounded-full border border-floof-dark/10 bg-white px-4 py-2 text-sm text-floof-dark focus:border-floof-pink focus:outline-none"
            onchange={`const cat='${catParam}'; const v=this.value; location.href='/store'+(cat!=='all'?'?cat='+cat+'&sort='+v:'?sort='+v)`}
          >
            <option value="featured" selected={sortParam === "featured"}>Featured</option>
            <option value="price-asc" selected={sortParam === "price-asc"}>Price: Low to high</option>
            <option value="price-desc" selected={sortParam === "price-desc"}>Price: High to low</option>
            <option value="name" selected={sortParam === "name"}>Name A–Z</option>
          </select>
        </div>
      </div>

      {filtered.length === 0 ? (
        <div class="py-20 text-center">
          <p class="text-lg font-semibold text-floof-dark">Nothing in this category yet</p>
          <a href="/store" class="mt-4 inline-block text-floof-pink underline">View all products</a>
        </div>
      ) : (
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {filtered.map((p, i) => (
            <ProductCard product={p} priority={i < 4} />
          ))}
        </div>
      )}

      <div class="mt-14 rounded-[1.25rem] bg-white p-8 md:p-10 outline outline-1 outline-floof-dark/6 text-center md:text-left md:flex md:items-center md:justify-between gap-6">
        <div>
          <h2 class="font-display text-xl font-semibold text-floof-dark">Not sure about sizing?</h2>
          <p class="mt-2 text-sm text-floof-dark/55 max-w-md">
            Unisex fits with room to move. Size guides live on every product page — when in doubt, size up.
          </p>
        </div>
        <a href="/shipping-returns" class="btn btn--ink mt-4 md:mt-0 shrink-0">
          Shipping & returns
        </a>
      </div>
    </section>
  )}
</Layout>
