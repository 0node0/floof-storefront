---
import Layout from "@/layouts/Layout.astro";
import Icon from "@/components/Icon.astro";
---
<Layout title="Contact" description="Get in touch with Floof!">
  <section class="border-b border-floof-dark/6 bg-floof-sand/50">
    <div class="mx-auto max-w-3xl px-6 py-14 text-center">
      <p class="eyebrow">Hello</p>
      <h1 class="mt-2 font-display text-4xl md:text-5xl font-semibold text-floof-dark">Hit us up</h1>
      <p class="mt-4 text-floof-dark/55">Questions, collab ideas, or just want to say hi?</p>
    </div>
  </section>
  <div class="mx-auto max-w-2xl px-6 py-16 grid sm:grid-cols-2 gap-6">
    <div class="text-center rounded-[1.25rem] bg-white p-8 outline outline-1 outline-floof-dark/6">
      <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-floof-sand text-floof-coral">
        <Icon name="spark" class="w-6 h-6" />
      </span>
      <p class="mt-3 font-medium text-floof-dark">Email</p>
      <a href="mailto:hello@floof.space" class="text-floof-pink hover:underline text-sm">hello@floof.space</a>
    </div>
    <div class="text-center rounded-[1.25rem] bg-white p-8 outline outline-1 outline-floof-dark/6">
      <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-floof-sand text-floof-coral">
        <Icon name="pin" class="w-6 h-6" />
      </span>
      <p class="mt-3 font-medium text-floof-dark">Location</p>
      <p class="text-floof-dark/60 text-sm">Southwest Florida</p>
    </div>
  </div>
</Layout>
