---
import Layout from "@/layouts/Layout.astro";
import Icon from "@/components/Icon.astro";
---
<Layout title="Contact" description="Get in touch with Floof!">
  <section class="bg-floof-dark text-white py-16">
    <div class="mx-auto max-w-7xl px-6 text-center">
      <h1 class="text-4xl font-bold md:text-5xl">Hit Us Up</h1>
      <p class="mt-4 text-white/60">Questions, collab ideas, or just want to say hi?</p>
    </div>
  </section>
  <div class="mx-auto max-w-2xl px-6 py-16 grid sm:grid-cols-2 gap-10">
    <div class="text-center rounded-3xl bg-white p-8 ring-1 ring-floof-dark/5">
      <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-floof-sand text-floof-dark">
        <Icon name="spark" class="w-6 h-6" />
      </span>
      <p class="mt-3 font-medium text-floof-dark">Email</p>
      <a href="mailto:hello@floof.space" class="text-floof-pink hover:underline text-sm">hello@floof.space</a>
    </div>
    <div class="text-center rounded-3xl bg-white p-8 ring-1 ring-floof-dark/5">
      <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-floof-sand text-floof-dark">
        <Icon name="pin" class="w-6 h-6" />
      </span>
      <p class="mt-3 font-medium text-floof-dark">Location</p>
      <p class="text-floof-dark/60 text-sm">Southwest Florida</p>
    </div>
  </div>
</Layout>
