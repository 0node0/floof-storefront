---
import Layout from "@/layouts/Layout.astro";
---
<Layout title="Contact" description="Get in touch with Floof!">
  <section class="bg-floof-dark text-white py-16"><div class="mx-auto max-w-7xl px-6 text-center"><h1 class="text-4xl font-bold md:text-5xl">Hit Us Up</h1><p class="mt-4 text-white/60">Questions, collab ideas, or just want to say hi?</p></div></section>
  <div class="mx-auto max-w-2xl px-6 py-16">
    <div class="text-center"><p class="text-2xl">📧</p><p class="mt-2 font-medium">Email</p><a href="mailto:hello@floof.space" class="text-floof-pink hover:underline">hello@floof.space</a></div>
    <div class="mt-8 text-center"><p class="text-2xl">📍</p><p class="mt-2 font-medium">Location</p><p class="text-floof-dark/60">Southwest Florida</p></div>
  </div>
</Layout>