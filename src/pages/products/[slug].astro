---
import Layout from "@/layouts/Layout.astro";
import ReactiveCartIsland from "@/components/ReactiveCartIsland";
import ProductCard from "@/components/ProductCard.astro";
import type { FloofProduct } from "@/components/ProductCard.astro";
import { listProducts, getProduct } from "@/lib/medusa";
import type { MedusaVariant } from "@/lib/medusa";

export const prerender = false;

const { slug } = Astro.params;

let product: FloofProduct | null = null;
let variants: MedusaVariant[] = [];
let image = "/favicon.svg";

try {
  const { product: raw } = await getProduct(slug || "");
  if (!raw) return Astro.redirect("/404");
  const colors = [...new Set(raw.variants?.map(v => v.options?.find(o => o.option?.title === "Color")?.value).filter(Boolean) as string[])];
  product = {
    id: raw.id, slug: raw.handle, name: raw.title,
    phrase: raw.title.split(" ").slice(0, 3).join(" "),
    description: raw.description || "", price: (raw.variants?.[0]?.prices?.[0]?.amount || 0) / 100,
    category: (raw.metadata?.category as string) || "tees",
    colors, image: raw.images?.[0]?.url || "",
  };
  variants = raw.variants || [];
  image = raw.images?.[0]?.url || "/favicon.svg";
} catch {
  return Astro.redirect("/404");
}

if (!product) return Astro.redirect("/404");
const ogImage = image || "/favicon.svg";
---
<Layout title={product.name} description={product.description} image={ogImage}>
  <div class="mx-auto max-w-7xl px-6 py-12">
    <nav class="mb-8 text-sm text-floof-dark/50"><a href="/" class="hover:text-floof-pink">Home</a><span class="mx-2">/</span><a href="/store" class="hover:text-floof-pink">Shop</a><span class="mx-2">/</span><span class="text-floof-dark">{product.name}</span></nav>
    <div class="grid gap-12 lg:grid-cols-2">
      <div class="aspect-square rounded-3xl bg-gradient-to-br from-floof-sand to-floof-cream p-12 flex items-center justify-center overflow-hidden">
        {image ? <img src={image} alt={product.name} class="w-full h-full object-contain" loading="eager" width="600" height="600" />
        : <span class="text-5xl md:text-6xl lg:text-7xl font-bold text-floof-dark/80 leading-tight text-center">{product.phrase}</span>}
      </div>
      <div class="flex flex-col justify-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-floof-coral">{product.category}</p>
        <h1 class="mt-2 text-3xl font-bold md:text-4xl text-floof-dark">{product.name}</h1>
        <p class="mt-4 text-lg text-floof-dark/60">{product.description}</p>
        {variants.length > 0 ? <ReactiveCartIsland client:visible product={product} variants={variants} /> : <p class="mt-8 text-sm italic text-floof-dark/50">Product variants syncing.</p>}
        <div class="mt-8 grid grid-cols-3 gap-4 border-t border-floof-dark/5 pt-8"><div class="text-center"><p class="text-lg">🌴</p><p class="mt-1 text-xs text-floof-dark/50">SW Florida Made</p></div><div class="text-center"><p class="text-lg">🚚</p><p class="mt-1 text-xs text-floof-dark/50">Real-Time Shipping</p></div><div class="text-center"><p class="text-lg">↩️</p><p class="mt-1 text-xs text-floof-dark/50">Easy Returns</p></div></div>
      </div>
    </div>
  </div>
</Layout>