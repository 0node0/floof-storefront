---
import Layout from "@/layouts/Layout.astro";
import ReactiveCartIsland from "@/components/ReactiveCartIsland";
import ProductCard from "@/components/ProductCard.astro";
import ProductJsonLd from "@/components/ProductJsonLd.astro";
import TrustBar from "@/components/TrustBar.astro";
import { listProducts, getProduct } from "@/lib/medusa";
import type { MedusaVariant } from "@/lib/medusa";
import { mapProduct, categoryLabels, type FloofProduct } from "@/lib/product";

export const prerender = false;

const { slug } = Astro.params;

let product: FloofProduct | null = null;
let variants: MedusaVariant[] = [];
let image = "/favicon.svg";
let related: FloofProduct[] = [];

try {
  const { product: raw } = await getProduct(slug || "");
  if (!raw) return Astro.redirect("/404");
  product = mapProduct(raw);
  variants = raw.variants || [];
  image = product.image || "/favicon.svg";

  // Related products same category
  try {
    const { products } = await listProducts();
    related = products
      .map(mapProduct)
      .filter((p) => p.slug !== product!.slug && p.category === product!.category)
      .slice(0, 4);
    if (related.length < 2) {
      related = products
        .map(mapProduct)
        .filter((p) => p.slug !== product!.slug)
        .slice(0, 4);
    }
  } catch {}
} catch {
  return Astro.redirect("/404");
}

if (!product) return Astro.redirect("/404");
const ogImage = image.startsWith("http") ? image : image;
const catLabel = categoryLabels[product.category] || product.category;
---
<Layout title={product.name} description={product.description || `Shop ${product.name} from Floof.`} image={ogImage}>
  <ProductJsonLd product={product} />

  <div class="mx-auto max-w-7xl px-6 py-8 md:py-12">
    <nav class="mb-8 text-sm text-floof-dark/50" aria-label="Breadcrumb">
      <ol class="flex flex-wrap items-center gap-1">
        <li><a href="/" class="hover:text-floof-pink">Home</a></li>
        <li aria-hidden="true" class="mx-1">/</li>
        <li><a href="/store" class="hover:text-floof-pink">Shop</a></li>
        <li aria-hidden="true" class="mx-1">/</li>
        <li><a href={`/store?cat=${product.category}`} class="hover:text-floof-pink capitalize">{catLabel}</a></li>
        <li aria-hidden="true" class="mx-1">/</li>
        <li class="text-floof-dark truncate max-w-[12rem] sm:max-w-none">{product.name}</li>
      </ol>
    </nav>

    <div class="grid gap-10 lg:grid-cols-2 lg:gap-14">
      <!-- Gallery -->
      <div class="space-y-4">
        <div class="aspect-square rounded-3xl bg-gradient-to-br from-floof-sand to-floof-cream p-8 md:p-12 flex items-center justify-center overflow-hidden ring-1 ring-floof-dark/5">
          {image && image !== "/favicon.svg" ? (
            <img
              src={image}
              alt={`${product.name} product photo`}
              class="w-full h-full object-contain"
              loading="eager"
              width="600"
              height="600"
            />
          ) : (
            <span class="text-4xl md:text-6xl font-bold text-floof-dark/80 leading-tight text-center">
              {product.phrase}
            </span>
          )}
        </div>
        <p class="text-center text-xs text-floof-dark/40">
          Colors shown as digital mockups · final print may vary slightly
        </p>
      </div>

      <!-- Buy box -->
      <div class="flex flex-col lg:justify-center">
        {product.isWip && (
          <span class="inline-flex w-fit rounded-full bg-floof-yellow/30 px-3 py-1 text-xs font-bold uppercase tracking-wider text-floof-dark mb-3">
            Design preview
          </span>
        )}
        <p class="text-sm font-semibold uppercase tracking-widest text-floof-coral">{catLabel}</p>
        <h1 class="mt-2 text-3xl font-bold md:text-4xl text-floof-dark leading-tight">{product.name}</h1>
        <p class="mt-4 text-base md:text-lg text-floof-dark/60 leading-relaxed">{product.description}</p>

        {variants.length > 0 ? (
          <ReactiveCartIsland client:load product={product} variants={variants} />
        ) : (
          <p class="mt-8 text-sm italic text-floof-dark/50">Variants syncing — check back shortly.</p>
        )}

        <!-- Accordion-style details -->
        <div class="mt-10 divide-y divide-floof-dark/10 border-t border-floof-dark/10">
          <details class="group py-4" open>
            <summary class="flex cursor-pointer list-none items-center justify-between font-semibold text-floof-dark">
              Shipping & fulfillment
              <span class="text-floof-dark/40 group-open:rotate-180 transition-transform">▾</span>
            </summary>
            <div class="mt-3 text-sm text-floof-dark/60 space-y-2 leading-relaxed">
              <p>Printed on demand in the US when you order — usually ships within 2–7 business days after production.</p>
              <p><strong class="text-floof-dark">Free standard shipping</strong> on orders $75+ (US).</p>
              <p><a href="/shipping-returns" class="text-floof-pink underline">Full shipping & returns policy</a></p>
            </div>
          </details>
          <details class="group py-4">
            <summary class="flex cursor-pointer list-none items-center justify-between font-semibold text-floof-dark">
              Materials & care
              <span class="text-floof-dark/40 group-open:rotate-180 transition-transform">▾</span>
            </summary>
            <div class="mt-3 text-sm text-floof-dark/60 space-y-2 leading-relaxed">
              <p>Soft retail blanks (tees & hoodies). Exact fabric depends on the style you pick.</p>
              <p>Machine wash cold, inside out. Tumble dry low. Do not iron directly on the print.</p>
            </div>
          </details>
          <details class="group py-4">
            <summary class="flex cursor-pointer list-none items-center justify-between font-semibold text-floof-dark">
              Returns
              <span class="text-floof-dark/40 group-open:rotate-180 transition-transform">▾</span>
            </summary>
            <div class="mt-3 text-sm text-floof-dark/60 space-y-2 leading-relaxed">
              <p>30 days on unworn items with tags. Because items are made to order, please double-check size before checkout.</p>
            </div>
          </details>
        </div>
      </div>
    </div>
  </div>

  <TrustBar compact />

  {related.length > 0 && (
    <section class="mx-auto max-w-7xl px-6 py-16">
      <div class="flex items-end justify-between gap-4 mb-8">
        <div>
          <p class="text-sm font-semibold uppercase tracking-widest text-floof-coral">You may also like</p>
          <h2 class="mt-1 text-2xl font-bold md:text-3xl text-floof-dark">More from the collection</h2>
        </div>
        <a href="/store" class="text-sm font-medium text-floof-pink underline shrink-0">Shop all</a>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {related.map((p) => <ProductCard product={p} />)}
      </div>
    </section>
  )}
</Layout>
